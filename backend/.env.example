# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/clientflow_crm?schema=public"

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_random_64_character_hex_string
JWT_REFRESH_SECRET=replace_with_a_different_random_64_character_hex_string

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
